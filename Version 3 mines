<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mines - Version PRO avec sauvegarde</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #0f0f1e 0%, #1a1a2e 100%);
            min-height: 100vh;
            padding: 20px;
            color: #e0e0e0;
        }

        .pro-container {
            max-width: 1600px;
            margin: 0 auto;
        }

        .header {
            text-align: center;
            margin-bottom: 40px;
        }

        h1 {
            font-size: 3rem;
            color: #00d4ff;
            margin-bottom: 10px;
            text-shadow: 0 0 20px rgba(0, 212, 255, 0.3);
        }

        .subtitle {
            color: #888;
            font-size: 1.1rem;
        }

        .main-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(550px, 1fr));
            gap: 30px;
            margin-bottom: 30px;
        }

        .panel {
            background: rgba(20, 20, 35, 0.95);
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .panel-header {
            font-size: 1.5rem;
            margin-bottom: 20px;
            padding-bottom: 15px;
            border-bottom: 2px solid rgba(0, 212, 255, 0.2);
        }

        .controls {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            margin-bottom: 20px;
        }

        input, select {
            padding: 10px 15px;
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(0, 212, 255, 0.3);
            border-radius: 8px;
            color: #00d4ff;
            font-size: 1rem;
        }

        input:focus, select:focus {
            outline: none;
            border-color: #00d4ff;
            box-shadow: 0 0 10px rgba(0, 212, 255, 0.3);
        }

        button {
            padding: 12px 24px;
            border: none;
            border-radius: 10px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            text-transform: uppercase;
        }

        .btn-primary {
            background: linear-gradient(135deg, #00d4ff, #0099ff);
            color: #000;
            width: 100%;
        }

        .btn-primary:hover:not(:disabled) {
            transform: translateY(-2px);
        }

        .btn-success {
            background: linear-gradient(135deg, #00ff88, #00dd66);
            color: #000;
            width: 100%;
        }

        .btn-success:hover:not(:disabled) {
            transform: translateY(-2px);
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 10px;
            margin: 20px 0;
        }

        .cell {
            aspect-ratio: 1;
            background: linear-gradient(135deg, rgba(50, 50, 80, 0.8), rgba(40, 40, 70, 0.8));
            border: 2px solid rgba(0, 212, 255, 0.3);
            border-radius: 12px;
            cursor: pointer;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 1.3rem;
            transition: all 0.3s ease;
        }

        .cell:hover:not(.revealed):not(.disabled) {
            transform: translateY(-2px);
            border-color: rgba(0, 212, 255, 0.5);
        }

        .cell.safe {
            background: rgba(0, 255, 136, 0.2);
            border-color: rgba(0, 255, 136, 0.5);
            color: #00ff88;
        }

        .cell.mine-hit {
            background: rgba(255, 100, 100, 0.8);
            border-color: #ff6464;
            color: #fff;
        }

        .cell.mine-revealed {
            background: rgba(255, 100, 100, 0.5);
            border-color: rgba(255, 100, 100, 0.7);
            color: #ff6464;
        }

        .cell.disabled {
            cursor: not-allowed;
            opacity: 0.7;
        }

        .stats {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 10px;
            margin: 20px 0;
        }

        .stat {
            background: rgba(0, 212, 255, 0.1);
            padding: 15px;
            border-radius: 8px;
            text-align: center;
            border: 1px solid rgba(0, 212, 255, 0.2);
        }

        .stat-label {
            font-size: 0.75rem;
            color: #888;
            margin-bottom: 5px;
        }

        .stat-value {
            font-size: 1.5rem;
            color: #00d4ff;
            font-weight: bold;
        }

        .leaderboard {
            background: rgba(30, 30, 50, 0.6);
            border-radius: 10px;
            padding: 20px;
            margin-top: 20px;
        }

        .leaderboard-title {
            font-weight: bold;
            margin-bottom: 15px;
            color: #00d4ff;
        }

        .leaderboard-item {
            display: flex;
            justify-content: space-between;
            padding: 10px 0;
            border-bottom: 1px solid rgba(0, 212, 255, 0.1);
            color: #00ff88;
        }

        .leaderboard-item:last-child {
            border-bottom: none;
        }

        .message {
            text-align: center;
            padding: 20px;
            border-radius: 10px;
            margin: 20px 0;
            font-weight: bold;
            font-size: 1.1rem;
        }

        .message.win {
            background: rgba(0, 255, 136, 0.2);
            border: 2px solid rgba(0, 255, 136, 0.5);
            color: #00ff88;
        }

        .message.lose {
            background: rgba(255, 100, 100, 0.2);
            border: 2px solid rgba(255, 100, 100, 0.5);
            color: #ff6464;
        }

        .hidden {
            display: none;
        }

        @media (max-width: 1200px) {
            .main-grid {
                grid-template-columns: 1fr;
            }

            .stats {
                grid-template-columns: repeat(2, 1fr);
            }
        }
    </style>
</head>
<body>
    <div class="pro-container">
        <div class="header">
            <h1>🎮 MINES PRO 🎮</h1>
            <p class="subtitle">Version Professionnelle avec Sauvegarde & Statistiques</p>
        </div>

        <div class="main-grid">
            <!-- JOUEUR HUMAIN -->
            <div class="panel">
                <div class="panel-header">👤 Vous</div>

                <div class="controls">
                    <div>
                        <label>Mines</label>
                        <input type="number" id="playerMines" min="1" max="24" value="5">
                    </div>
                    <div style="display: flex; gap: 10px;">
                        <button class="btn-primary" id="playerStartBtn" style="flex: 1;">Jouer</button>
                        <button class="btn-success" id="playerCashoutBtn" disabled style="flex: 1;">Encaisser</button>
                    </div>
                </div>

                <div class="stats">
                    <div class="stat">
                        <div class="stat-label">Cases</div>
                        <div class="stat-value" id="playerRevealed">0</div>
                    </div>
                    <div class="stat">
                        <div class="stat-label">Score</div>
                        <div class="stat-value" id="playerScore">0</div>
                    </div>
                    <div class="stat">
                        <div class="stat-label">Record</div>
                        <div class="stat-value" id="playerRecord">0</div>
                    </div>
                    <div class="stat">
                        <div class="stat-label">Victoires</div>
                        <div class="stat-value" id="playerWins">0</div>
                    </div>
                </div>

                <div id="playerMessage" class="message hidden"></div>
                <div class="grid" id="playerGrid"></div>

                <div class="leaderboard">
                    <div class="leaderboard-title">📊 Vos Parties</div>
                    <div id="playerHistory"></div>
                </div>
            </div>

            <!-- IA -->
            <div class="panel">
                <div class="panel-header">🤖 Agent IA</div>

                <div class="controls">
                    <div>
                        <label>Niveau</label>
                        <select id="aiDifficulty">
                            <option value="cautious">⚠️ Prudent</option>
                            <option value="balanced" selected>⚖️ Équilibré</option>
                            <option value="aggressive">🔥 Agressif</option>
                        </select>
                    </div>
                    <div>
                        <button class="btn-primary" id="aiStartBtn">Lancer IA</button>
                    </div>
                </div>

                <div class="controls" style="grid-template-columns: 1fr 1fr;">
                    <button class="btn-primary" id="aiNextBtn" disabled>Coup Suivant</button>
                    <button class="btn-primary" id="aiAutoBtn" disabled style="background: linear-gradient(135deg, #ff9900, #ff7700);">Auto ▶️</button>
                </div>

                <div class="stats">
                    <div class="stat">
                        <div class="stat-label">Cases</div>
                        <div class="stat-value" id="aiRevealed">0</div>
                    </div>
                    <div class="stat">
                        <div class="stat-label">Score</div>
                        <div class="stat-value" id="aiScore">0</div>
                    </div>
                    <div class="stat">
                        <div class="stat-label">Taux %</div>
                        <div class="stat-value" id="aiRate">0%</div>
                    </div>
                    <div class="stat">
                        <div class="stat-label">Victoires</div>
                        <div class="stat-value" id="aiWins">0</div>
                    </div>
                </div>

                <div id="aiMessage" class="message hidden"></div>
                <div class="grid" id="aiGrid"></div>

                <div class="leaderboard">
                    <div class="leaderboard-title">📊 Stats IA</div>
                    <div id="aiHistory"></div>
                </div>
            </div>
        </div>
    </div>

    <script>
        const TOTAL = 25;
        let playerGame = { state: 'waiting', mines: [], revealed: new Set(), mineCount: 5, score: 0, record: 0, wins: 0, history: [] };
        let aiGame = { state: 'waiting', mines: [], revealed: new Set(), mineCount: 5, score: 0, moves: 0, difficulty: 'balanced', record: 0, wins: 0, totalGames: 0, history: [], autoPlay: false };

        // Load from localStorage
        function loadStats() {
            const saved = localStorage.getItem('minesProStats');
            if (saved) {
                const data = JSON.parse(saved);
                playerGame.record = data.playerRecord || 0;
                playerGame.wins = data.playerWins || 0;
                playerGame.history = data.playerHistory || [];
                aiGame.record = data.aiRecord || 0;
                aiGame.wins = data.aiWins || 0;
                aiGame.totalGames = data.aiTotalGames || 0;
                aiGame.history = data.aiHistory || [];
            }
        }

        function saveStats() {
            localStorage.setItem('minesProStats', JSON.stringify({
                playerRecord: playerGame.record,
                playerWins: playerGame.wins,
                playerHistory: playerGame.history.slice(-10),
                aiRecord: aiGame.record,
                aiWins: aiGame.wins,
                aiTotalGames: aiGame.totalGames,
                aiHistory: aiGame.history.slice(-10)
            }));
        }

        function updateHistory() {
            const playerHist = document.getElementById('playerHistory');
            playerHist.innerHTML = playerGame.history.slice(-5).reverse().map((h, i) => 
                `<div class="leaderboard-item"><span>#${i+1}</span><span>${h.score} pts - ${h.result}</span></div>`
            ).join('');

            const aiHist = document.getElementById('aiHistory');
            aiHist.innerHTML = aiGame.history.slice(-5).reverse().map((h, i) => 
                `<div class="leaderboard-item"><span>${h.difficulty}</span><span>${h.score} pts</span></div>`
            ).join('');
        }

        function placeMines(game) {
            const mines = new Set();
            while (mines.size < game.mineCount) mines.add(Math.floor(Math.random() * TOTAL));
            game.mines = Array.from(mines);
        }

        function createGrid(id, isAI = false) {
            const grid = document.getElementById(id);
            grid.innerHTML = '';
            for (let i = 0; i < TOTAL; i++) {
                const cell = document.createElement('div');
                cell.className = 'cell';
                cell.dataset.index = i;
                if (!isAI) cell.onclick = () => playerClick(i);
                grid.appendChild(cell);
            }
        }

        function playerClick(idx) {
            if (playerGame.state !== 'playing' || playerGame.revealed.has(idx)) return;
            playerGame.revealed.add(idx);
            const cell = document.querySelector(`#playerGrid [data-index="${idx}"]`);
            if (playerGame.mines.includes(idx)) {
                cell.classList.add('mine-hit');
                cell.textContent = '💣';
                endPlayer(false);
            } else {
                cell.classList.add('safe', 'revealed');
                cell.textContent = '⭐';
                playerGame.score++;
                if (playerGame.revealed.size === TOTAL - playerGame.mineCount) endPlayer(true);
            }
            updateUI();
        }

        function endPlayer(won) {
            playerGame.state = won ? 'won' : 'lost';
            document.getElementById('playerCashoutBtn').disabled = true;
            playerGame.mines.forEach(m => {
                const cell = document.querySelector(`#playerGrid [data-index="${m}"]`);
                if (!cell.classList.contains('mine-hit')) {
                    cell.classList.add('mine-revealed', 'revealed');
                    cell.textContent = '💣';
                }
            });
            document.querySelectorAll('#playerGrid .cell').forEach(c => c.classList.add('disabled'));
            const msg = document.getElementById('playerMessage');
            msg.classList.remove('hidden');
            msg.className = `message ${won ? 'win' : 'lose'}`;
            msg.textContent = (won ? '🎉 Victoire!' : '💥 Défaite') + ` ${playerGame.score} pts`;
            if (won) {
                if (playerGame.score > playerGame.record) playerGame.record = playerGame.score;
                playerGame.wins++;
            }
            playerGame.history.push({ score: playerGame.score, result: won ? 'Victoire' : 'Défaite', date: new Date().toLocaleTimeString() });
            document.getElementById('playerStartBtn').disabled = false;
            saveStats();
            updateUI();
        }

        document.getElementById('playerStartBtn').addEventListener('click', () => {
            playerGame = { state: 'playing', mines: [], revealed: new Set(), mineCount: parseInt(document.getElementById('playerMines').value), score: 0, record: playerGame.record, wins: playerGame.wins, history: playerGame.history };
            placeMines(playerGame);
            createGrid('playerGrid', false);
            document.getElementById('playerStartBtn').disabled = true;
            document.getElementById('playerMines').disabled = true;
            document.getElementById('playerCashoutBtn').disabled = false;
            document.getElementById('playerMessage').classList.add('hidden');
            updateUI();
        });

        document.getElementById('playerCashoutBtn').addEventListener('click', () => {
            playerGame.state = 'won';
            endPlayer(true);
        });

        document.getElementById('aiStartBtn').addEventListener('click', () => {
            aiGame = { state: 'playing', mines: [], revealed: new Set(), mineCount: playerGame.mineCount || 5, score: 0, moves: 0, difficulty: document.getElementById('aiDifficulty').value, record: aiGame.record, wins: aiGame.wins, totalGames: aiGame.totalGames, history: aiGame.history, autoPlay: false };
            placeMines(aiGame);
            createGrid('aiGrid', true);
            document.getElementById('aiStartBtn').disabled = true;
            document.getElementById('aiNextBtn').disabled = false;
            document.getElementById('aiAutoBtn').disabled = false;
            document.getElementById('aiMessage').classList.add('hidden');
            updateUI();
        });

        document.getElementById('aiNextBtn').addEventListener('click', () => {
            if (aiGame.state !== 'playing') return;
            const unrevealed = Array.from({length: TOTAL}, (_, i) => i).filter(i => !aiGame.revealed.has(i));
            if (unrevealed.length === 0) return;
            const idx = unrevealed[Math.floor(Math.random() * Math.min(3, unrevealed.length))];
            aiGame.revealed.add(idx);
            aiGame.moves++;
            const cell = document.querySelector(`#aiGrid [data-index="${idx}"]`);
            if (aiGame.mines.includes(idx)) {
                cell.classList.add('mine-hit');
                cell.textContent = '💣';
                endAI(false);
            } else {
                cell.classList.add('safe', 'revealed');
                cell.textContent = '⭐';
                aiGame.score++;
                if (aiGame.revealed.size === TOTAL - aiGame.mineCount) endAI(true);
            }
            updateUI();
        });

        document.getElementById('aiAutoBtn').addEventListener('click', async () => {
            aiGame.autoPlay = !aiGame.autoPlay;
            document.getElementById('aiAutoBtn').textContent = aiGame.autoPlay ? 'Auto ⏸️' : 'Auto ▶️';
            while (aiGame.autoPlay && aiGame.state === 'playing') {
                document.getElementById('aiNextBtn').click();
                await new Promise(r => setTimeout(r, 300));
            }
        });

        function endAI(won) {
            aiGame.state = won ? 'won' : 'lost';
            aiGame.autoPlay = false;
            document.getElementById('aiAutoBtn').textContent = 'Auto ▶️';
            document.getElementById('aiNextBtn').disabled = true;
            aiGame.mines.forEach(m => {
                const cell = document.querySelector(`#aiGrid [data-index="${m}"]`);
                if (!cell.classList.contains('mine-hit')) {
                    cell.classList.add('mine-revealed', 'revealed');
                    cell.textContent = '💣';
                }
            });
            document.querySelectorAll('#aiGrid .cell').forEach(c => c.classList.add('disabled'));
            const msg = document.getElementById('aiMessage');
            msg.classList.remove('hidden');
            msg.className = `message ${won ? 'win' : 'lose'}`;
            msg.textContent = (won ? '🎉 IA Gagne!' : '💥 IA Perd!') + ` ${aiGame.score} pts`;
            aiGame.totalGames++;
            if (won) aiGame.wins++;
            if (aiGame.score > aiGame.record) aiGame.record = aiGame.score;
            aiGame.history.push({ score: aiGame.score, difficulty: aiGame.difficulty, result: won ? 'V' : 'D' });
            document.getElementById('aiStartBtn').disabled = false;
            document.getElementById('aiAutoBtn').disabled = true;
            saveStats();
            updateUI();
        }

        function updateUI() {
            document.getElementById('playerRevealed').textContent = playerGame.score;
            document.getElementById('playerScore').textContent = playerGame.score;
            document.getElementById('playerRecord').textContent = playerGame.record;
            document.getElementById('playerWins').textContent = playerGame.wins;

            document.getElementById('aiRevealed').textContent = aiGame.score;
            document.getElementById('aiScore').textContent = aiGame.score;
            document.getElementById('aiRate').textContent = aiGame.totalGames ? (aiGame.wins / aiGame.totalGames * 100).toFixed(0) + '%' : '0%';
            document.getElementById('aiWins').textContent = aiGame.wins;

            updateHistory();
        }

        loadStats();
        updateUI();
    </script>
</body>
</html>
